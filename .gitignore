# Secrets and environment files — never commit these
.env
.env.*
!.env.tmpl

# Generated config directories that may contain secrets
generated/
deployed/

# Secret file types
*.secret
*.key
*.pem
*.p12
*.pfx

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.pnp/
.yarn/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Logs
*.log
logs/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# Editor temp files
*.swp
*.swo
*.bak
*.orig
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# tmux
.tmux-resurrect/

# Runtime state (generated at deploy time)
runtime/
