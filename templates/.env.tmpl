# .env — Environment variables for {{AGENT_NAME}}
#
# This file is generated by setup.sh and should NEVER be committed to git.
# It is listed in .gitignore. Keep it private.
#
# To add new variables: edit this file and restart the assistant.
# Reference these with $VARIABLE_NAME in scripts or via `source .env` at the top.
#
# Format: export KEY="value"
# ─────────────────────────────────────────────────────────────────────────────


# ── Base Configuration ────────────────────────────────────────────────────────

# Name of the assistant (used for tmux session, directory names)
export AGENT_NAME="{{AGENT_NAME}}"

# Your full name — the assistant will use this to verify identity
export USER_NAME="{{USER_NAME}}"

# Your timezone (e.g., US/Central, America/Chicago, Europe/London)
export USER_TIMEZONE="{{USER_TIMEZONE}}"

# Base directory where runtime and config directories are created
export DEPLOY_BASE="{{DEPLOY_BASE}}"

# Which secrets manager to use: 1password | bitwarden | env-only
export SECRETS_MANAGER="{{SECRETS_MANAGER}}"


# ── Secrets Manager ───────────────────────────────────────────────────────────

# 1Password: name of the vault to read secrets from
# export OP_VAULT="Personal"

# 1Password: service account token (if using a service account instead of interactive login)
# export OP_SERVICE_ACCOUNT_TOKEN=""

# Bitwarden: server URL (default: https://vault.bitwarden.com)
# export BW_URL="https://vault.bitwarden.com"

# Bitwarden: session token (set after `bw unlock` — expires on logout)
# export BW_SESSION=""


# ── Messaging: Telegram ───────────────────────────────────────────────────────

# Bot token from @BotFather — create a bot with /newbot
# export TELEGRAM_BOT_TOKEN=""

# Your personal Telegram chat ID — get it from @userinfobot
# export TELEGRAM_CHAT_ID=""

# Optional: allowed user IDs (comma-separated) for multi-user bots
# export TELEGRAM_ALLOWED_USERS=""


# ── Messaging: Discord ────────────────────────────────────────────────────────

# Discord bot token from https://discord.com/developers/applications
# export DISCORD_BOT_TOKEN=""

# The specific channel ID the assistant should listen to
# export DISCORD_CHANNEL_ID=""

# Discord guild (server) ID
# export DISCORD_GUILD_ID=""


# ── Messaging: iMessage (macOS only) ─────────────────────────────────────────

# Your phone number or Apple ID email for iMessage routing
# export IMESSAGE_ADDRESS=""


# ── Calendar: Google Workspace ────────────────────────────────────────────────

# Google account email for gws CLI authentication
# export GWS_ACCOUNT=""

# Path to gws CLI binary (if not in PATH)
# export GWS_BIN="/usr/local/bin/gws"

# gws credentials directory (default: ~/.config/gws)
# export GWS_CONFIG_DIR="${HOME}/.config/gws"


# ── Storage: Obsidian ─────────────────────────────────────────────────────────

# Absolute path to your Obsidian vault directory
# export OBSIDIAN_VAULT="${HOME}/Documents/vault"

# Daily notes folder within the vault (relative to vault root)
# export OBSIDIAN_DAILY_DIR="Daily"

# Template to use for new daily notes (relative to vault root)
# export OBSIDIAN_DAILY_TEMPLATE="Templates/Daily Note.md"


# ── Memory: LCM ───────────────────────────────────────────────────────────────

# Maximum number of lines to keep in the compacted context file
# export LCM_MAX_CONTEXT_LINES="500"

# Number of days of session logs to keep before archiving
# export LCM_SESSION_RETENTION_DAYS="30"


# ── Agents: Fitness ───────────────────────────────────────────────────────────

# Fitness data source: apple-health | garmin | manual
# export FITNESS_DATA_SOURCE="manual"

# Path to health data export (if using apple-health CSV export)
# export FITNESS_DATA_PATH=""


# ── Agents: Job Search ────────────────────────────────────────────────────────

# Path to your resume file (PDF or markdown)
# export JOB_RESUME_PATH=""

# Job boards to monitor (comma-separated)
# export JOB_BOARDS="linkedin,indeed"


# ── Agents: System Health ────────────────────────────────────────────────────

# Services to monitor (comma-separated systemd service names)
# export SYSHEALTH_SERVICES=""

# Disk usage alert threshold (percentage)
# export SYSHEALTH_DISK_THRESHOLD="85"

# Notification channel for alerts: telegram | discord | log
# export SYSHEALTH_ALERT_CHANNEL="telegram"


# ── Optional: ElevenLabs TTS ─────────────────────────────────────────────────

# ElevenLabs API key for text-to-speech output
# export ELEVENLABS_API_KEY=""

# Voice ID to use for synthesis
# export ELEVENLABS_VOICE_ID=""


# ── Optional: Tailscale / Remote Access ──────────────────────────────────────

# Tailscale hostname or IP of a remote machine (e.g., Mac for browser automation)
# export TAILSCALE_MAC_HOST=""

# SSH user for remote Tailscale connections
# export TAILSCALE_SSH_USER=""


# ── Optional: Web Search ──────────────────────────────────────────────────────

# Brave Search API key (for research agent)
# export BRAVE_SEARCH_API_KEY=""

# Serper API key (alternative search provider)
# export SERPER_API_KEY=""


# ── Optional: Pushover Notifications ─────────────────────────────────────────

# Pushover application token
# export PUSHOVER_APP_TOKEN=""

# Pushover user key
# export PUSHOVER_USER_KEY=""
