#!/usr/bin/env bash
# Start (or attach to) the {{AGENT_NAME}} assistant session
# Generated by personal-ai-playbook setup.sh
set -euo pipefail

AGENT_NAME="{{AGENT_NAME}}"
DEPLOY_BASE="{{DEPLOY_BASE}}"
RUNTIME_DIR="${DEPLOY_BASE}/.${AGENT_NAME}"
STATE_FILE="${RUNTIME_DIR}/state/running"
LOG_FILE="${RUNTIME_DIR}/state/start.log"
SESSION_LOG="${RUNTIME_DIR}/memory/sessions/$(date +%Y-%m-%d_%H%M%S).md"

# Source environment
if [[ -f "${DEPLOY_BASE}/.env" ]]; then
  source "${DEPLOY_BASE}/.env"
else
  echo "Warning: ${DEPLOY_BASE}/.env not found. Secrets may be unavailable." >&2
fi

# Create required directories
mkdir -p "${RUNTIME_DIR}/state"
mkdir -p "${RUNTIME_DIR}/memory/sessions"

# If already running, attach and exit
if tmux has-session -t "${AGENT_NAME}" 2>/dev/null; then
  echo "Session '${AGENT_NAME}' is already running. Attaching..."
  tmux attach-session -t "${AGENT_NAME}"
  exit 0
fi

echo "Starting ${AGENT_NAME}..." | tee -a "$LOG_FILE"
echo "Runtime: ${RUNTIME_DIR}" | tee -a "$LOG_FILE"
echo "Started: $(date)" | tee -a "$LOG_FILE"

# Load memory context for startup prompt injection
MEMORY_SCRIPT="${RUNTIME_DIR}/scripts/load-memory.sh"
if [[ -x "$MEMORY_SCRIPT" ]]; then
  MEMORY_CONTEXT="$("${MEMORY_SCRIPT}" 2>/dev/null || true)"
else
  MEMORY_CONTEXT=""
fi

# Build system prompt
SYSTEM_PROMPT_PARTS=()

# Persona from SOUL.md
SOUL_FILE="${RUNTIME_DIR}/SOUL.md"
if [[ -f "$SOUL_FILE" ]]; then
  SOUL_CONTENT="$(cat "$SOUL_FILE")"
  SYSTEM_PROMPT_PARTS+=("$SOUL_CONTENT")
fi

# Memory context
if [[ -n "$MEMORY_CONTEXT" ]]; then
  SYSTEM_PROMPT_PARTS+=("$MEMORY_CONTEXT")
fi

# Combine parts
COMBINED_PROMPT="$(printf '%s\n\n' "${SYSTEM_PROMPT_PARTS[@]}")"

# Build the claude command
CLAUDE_CMD=(
  claude
  --dangerously-skip-permissions
  {{CHANNEL_FLAG}}
  --append-system-prompt "${COMBINED_PROMPT}"
)

# Remove empty flags
CLAUDE_CMD=("${CLAUDE_CMD[@]/#--channel-flag-placeholder/}")

# Create a new tmux session running the assistant
tmux new-session -d -s "${AGENT_NAME}" -x 220 -y 50

# Set working directory to runtime dir
tmux send-keys -t "${AGENT_NAME}" "cd '${RUNTIME_DIR}'" Enter

# Source env inside the session too
tmux send-keys -t "${AGENT_NAME}" "source '${DEPLOY_BASE}/.env'" Enter

# Start session log
tmux send-keys -t "${AGENT_NAME}" "echo '# Session: $(date -I)' > '${SESSION_LOG}'" Enter

# Launch the assistant
tmux send-keys -t "${AGENT_NAME}" "${CLAUDE_CMD[*]}" Enter

# Mark as running
echo "$(date -Iseconds)" > "$STATE_FILE"

echo "${AGENT_NAME} started in tmux session '${AGENT_NAME}'."
echo "Attach with: tmux attach -t ${AGENT_NAME}"
echo "Stop with:   ${DEPLOY_BASE}/stop-${AGENT_NAME}.sh"
